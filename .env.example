# Supabase — populated in Phase 3 (Database) once a project exists.
# See docs/03-tech-stack.md and docs/05-auth-flow.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses RLS. Never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used for metadataBase/OpenGraph/sitemap/robots (Phase 12).
# Defaults to http://localhost:3000 if unset; set to the real domain in
# Phase 14 (Deployment).
NEXT_PUBLIC_SITE_URL=
